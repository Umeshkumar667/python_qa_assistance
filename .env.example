# ─────────────────────────────────────────────────────────────────────────────
# .env.example  — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "groq" (default) | "openai" | "anthropic"
LLM_PROVIDER=groq

# ── Groq ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-20b

# ── OpenAI (only needed when LLM_PROVIDER=openai) ────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic (only needed when LLM_PROVIDER=anthropic) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Embeddings ────────────────────────────────────────────────────────────────
# Using HuggingFace sentence-transformers model (runs locally, no API key needed)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ── Vector store ──────────────────────────────────────────────────────────────
# Path (relative to project root) where the FAISS index is stored.
VECTORSTORE_PATH=data/vectorstore

# ── RAG tuning ────────────────────────────────────────────────────────────────
VECTORSTORE_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_TOKENS=1024
TEMPERATURE=0.2